JWT_SECRET="your_jwt_secret_key_here"
ADMIN_PASSWORD="your_admin_password_here"
DB_USER="admin"
DB_PASSWORD="admin1234"
DB_NAME="{{DB_NAME}}"
DB_HOST="localhost"
DB_PORT="5432"
DATABASE_URL="postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}?schema=public&connection_limit=5"

# Server
PORT=5000
HOST=0.0.0.0
NODE_ENV=development

# Swagger
SWAGGER_ENABLED=true
SWAGGER_PATH=/docs
SWAGGER_TITLE={{APP_NAME}} API

# Logging
LOG_LEVEL=debug
LOG_FORMAT=text
