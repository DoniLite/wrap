JWT_SECRET="your_jwt_secret_key_here"

# Upstream API this app aggregates/fronts
EXTERNAL_API_BASE_URL="https://example.com"

# Server
PORT=5000
HOST=0.0.0.0
NODE_ENV=development

# Swagger
SWAGGER_ENABLED=true
SWAGGER_PATH=/docs
SWAGGER_TITLE={{APP_NAME}} API

# Logging
LOG_LEVEL=debug
LOG_FORMAT=text
