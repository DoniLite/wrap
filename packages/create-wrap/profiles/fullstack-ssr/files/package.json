{
  "name": "wrap-template",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "start": "NODE_ENV=production bun run src/index.ts",
    "fmt": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "lint": "bunx eslint .",
    "lint:fix": "bunx eslint . --ext .js,.ts --fix",
    "init:env": "cp ./.env.example ./.env",
    "init:all": "bun init:env && bun install",
    "test": "bun test"
  },
  "devDependencies": {
    "@eslint/js": "^10",
    "@types/bun": "latest",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10",
    "globals": "^17.0.0",
    "jiti": "^2.7.0",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1"
  },
  "dependencies": {
    "@donilite/wrap": "workspace:*",
    "@tanstack/react-router": "^1.170.17",
    "dotenv": "^17.2.0",
    "dotenv-expand": "^13",
    "drizzle-orm": "^0.45.0",
    "drizzle-zod": "^0.8.3",
    "hono": "^4.12.27",
    "pg": "^8.16.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "reflect-metadata": "^0.2.2",
    "zod": "^4.4.3"
  }
}
