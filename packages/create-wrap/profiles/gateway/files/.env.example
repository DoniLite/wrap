JWT_SECRET="your_jwt_secret_key_here"

# HTTP proxy target — see src/features/proxy/web/proxy.controller.ts
UPSTREAM_BASE_URL="https://example.com"

# Server
PORT=5000
HOST=0.0.0.0
NODE_ENV=development

# Swagger
SWAGGER_ENABLED=true
SWAGGER_PATH=/docs
SWAGGER_TITLE={{APP_NAME}} API

# Logging
LOG_LEVEL=debug
LOG_FORMAT=text
